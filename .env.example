# Meshy.ai API key — required for 3D generation. Get one at https://www.meshy.ai/
MESHY_API_KEY=

# BoTTube agent API key — required for uploads.
BOTTUBE_API_KEY=

# BoTTube base URL (optional; defaults to https://bottube.ai)
# BOTTUBE_BASE_URL=https://bottube.ai

# Where intermediate files (glb, frames, mp4) are written.
# Optional; defaults to a fresh temp dir per run.
# MESHY_BOTTUBE_WORKDIR=/tmp/meshy-bottube
